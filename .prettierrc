{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^(next|next-intl)(/.*)?$",
    "^react$",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@(repo|web|products|community)/",
    "",
    "^\\.(?!.*\\.scss$)",
    "",
    ".*globals.*",
    "^clsx$",
    "\\.scss$"
  ],
  "importOrderTypeScriptVersion": "5.0.0"
}
